---
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  canonicalURL,
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Small Biz Security</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Small Biz Security" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Canonical -->
    {canonicalURL ? (
      <link rel="canonical" href={canonicalURL} />
    ) : (
      <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    )}

    <!-- Schema: WebSite -->
    <script type="application/ld+json" set:html={`{
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Small Biz Security",
      "url": "${Astro.site}",
      "description": "Free cybersecurity guides, tools, and resources for small business owners. No technical jargon, just practical steps to protect your business.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "${Astro.site}/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="flex min-h-screen flex-col">
    <header class="sticky top-0 z-50 border-b border-gray-100 bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/80">
      <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8" aria-label="Main navigation">
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-primary-700 no-underline">
          <span class="text-2xl" role="img" aria-label="shield">🛡️</span>
          <span>Small Biz Security</span>
        </a>
        <div class="hidden items-center gap-8 sm:flex">
          <a href="/tools/" class="text-sm font-medium text-gray-600 hover:text-primary-700 transition-colors">Tools</a>
          <a href="/blog/" class="text-sm font-medium text-gray-600 hover:text-primary-700 transition-colors">Guides</a>
          <a href="/about/" class="text-sm font-medium text-gray-600 hover:text-primary-700 transition-colors">About</a>
          <a href="/contact/" class="text-sm font-medium text-gray-600 hover:text-primary-700 transition-colors">Contact</a>
        </div>
        <button class="sm:hidden rounded-lg p-2 text-gray-600 hover:bg-gray-100" id="mobile-menu-btn" aria-label="Open menu">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
        </button>
      </nav>
      <!-- Mobile menu -->
      <div class="hidden sm:hidden border-t border-gray-100 bg-white px-4 py-3" id="mobile-menu">
        <div class="flex flex-col gap-3">
          <a href="/tools/" class="text-sm font-medium text-gray-600 hover:text-primary-700">Tools</a>
          <a href="/blog/" class="text-sm font-medium text-gray-600 hover:text-primary-700">Guides</a>
          <a href="/about/" class="text-sm font-medium text-gray-600 hover:text-primary-700">About</a>
          <a href="/contact/" class="text-sm font-medium text-gray-600 hover:text-primary-700">Contact</a>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-gray-100 bg-gray-50">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
          <div>
            <h3 class="text-sm font-semibold text-gray-900">Small Biz Security</h3>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              Practical cybersecurity advice for small business owners. No jargon, just actionable steps.
            </p>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-900">Resources</h3>
            <ul class="mt-3 space-y-2">
              <li><a href="/tools/" class="text-sm text-gray-600 hover:text-primary-700">Free Tools</a></li>
              <li><a href="/blog/" class="text-sm text-gray-600 hover:text-primary-700">Guides & Articles</a></li>
              <li><a href="/blog/cybersecurity-101/" class="text-sm text-gray-600 hover:text-primary-700">Cybersecurity 101</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-900">Company</h3>
            <ul class="mt-3 space-y-2">
              <li><a href="/about/" class="text-sm text-gray-600 hover:text-primary-700">About</a></li>
              <li><a href="/contact/" class="text-sm text-gray-600 hover:text-primary-700">Contact</a></li>
              <li><a href="/privacy/" class="text-sm text-gray-600 hover:text-primary-700">Privacy Policy</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-10 border-t border-gray-200 pt-6">
          <p class="text-xs text-gray-500">&copy; {new Date().getFullYear()} Small Biz Security. All rights reserved. This site provides general information and does not constitute professional security advice.</p>
        </div>
      </div>
    </footer>

    <script>
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
