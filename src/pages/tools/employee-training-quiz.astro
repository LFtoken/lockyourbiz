---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrainingQuizGenerator from '../../components/TrainingQuizGenerator';
---

<BaseLayout
  title="Employee Security Training Quiz Generator | Free Custom Quizzes"
  description="Generate custom security training quizzes for your team. Pick from phishing awareness, password security, remote work safety, and data privacy topics."
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center mb-12">
      <h1 class="text-4xl font-extrabold tracking-tight text-gray-900">Employee Security Training Quiz Generator</h1>
      <p class="mt-4 text-lg text-gray-600">
        Generate custom security training quizzes for your team meetings. Pick a topic, take the quiz to preview it, then use the questions in your next training session. Four topics, 20 total questions with detailed explanations.
      </p>
      <div class="mt-4 inline-flex items-center gap-2 rounded-full bg-accent-50 px-4 py-1.5 text-sm font-medium text-accent-700">
        👥 Free training resource — use these quizzes in your team meetings
      </div>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white p-6 sm:p-10 shadow-sm max-w-2xl mx-auto">
      <TrainingQuizGenerator client:load />
    </div>
  </div>
</BaseLayout>
