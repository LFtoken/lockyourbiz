---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SmbBudgetCalculator from '../../components/SmbBudgetCalculator';
---

<BaseLayout
  title="SMB Security Budget Calculator | Free Planning Tool"
  description="Calculate your recommended cybersecurity budget based on company size, industry, and risk profile. Get a detailed breakdown by category with specific tool recommendations."
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center mb-12">
      <h1 class="text-4xl font-extrabold tracking-tight text-gray-900">SMB Security Budget Calculator</h1>
      <p class="mt-4 text-lg text-gray-600">
        How much should your small business spend on cybersecurity? Adjust the sliders and get a recommended annual budget with a detailed breakdown across 7 spending categories.
      </p>
      <div class="mt-4 inline-flex items-center gap-2 rounded-full bg-accent-50 px-4 py-1.5 text-sm font-medium text-accent-700">
        💰 Instant calculation — processed entirely in your browser
      </div>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white p-6 sm:p-10 shadow-sm max-w-2xl mx-auto">
      <SmbBudgetCalculator client:load />
    </div>
  </div>
</BaseLayout>
