---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
---

<BaseLayout
  title="Free Cybersecurity Tools"
  description="Free, no-signup cybersecurity tools for small business owners. Security assessment, password checker, and security tool comparison."
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-gray-900">Free Security Tools</h1>
      <p class="mt-4 text-lg text-gray-600">
        No sign-up. No email collection. No catch. Just practical tools to help protect your business.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <ToolCard
        title="Security Assessment"
        description="Answer 20 questions and get a personalized risk score with actionable recommendations to improve your security posture. Takes 3 minutes."
        icon="📋"
        href="/tools/security-assessment/"
      />
      <ToolCard
        title="Password Strength Checker"
        description="Test how strong your passwords really are. See estimated crack times, get a detailed checklist, and learn what makes a password strong."
        icon="🔐"
        href="/tools/password-checker/"
      />
      <ToolCard
        title="Phishing Email Quiz"
        description="10 realistic emails. Can you tell which are scams? Learn the patterns with instant feedback and expert explanations. No sign-up, 5 minutes."
        icon="🎣"
        href="/tools/phishing-quiz/"
      />
      <ToolCard
        title="Free Tool Comparison"
        description="Compare the best free security tools side by side. Find the right password manager, antivirus, backup solution, and firewall for your business."
        icon="⚖️"
        href="/tools/tool-comparison/"
      />
      <ToolCard
        title="GDPR Compliance Tester"
        description="Not sure if you are GDPR-ready? Answer 8 questions and get an instant compliance score with specific recommendations and next steps."
        icon="🇪🇺"
        href="/tools/gdpr-compliance-tester/"
      />
      <ToolCard
        title="Website Vulnerability Scanner"
        description="12-point guided security checklist for your business website. Check SSL, WAF, CMS updates, backups — with exact fix instructions for each issue."
        icon="🌐"
        href="/tools/website-vulnerability-scanner/"
      />
      <ToolCard
        title="SMB Security Budget Calculator"
        description="How much should you spend on cybersecurity? Get a personalized budget breakdown by category with specific tool recommendations."
        icon="💰"
        href="/tools/smb-budget-calculator/"
      />
      <ToolCard
        title="MFA Eligibility Checker"
        description="Which of your services support two-factor authentication? Select your tools and get step-by-step MFA setup instructions for each one."
        icon="🔐"
        href="/tools/mfa-eligibility-checker/"
      />
      <ToolCard
        title="Employee Training Quiz Generator"
        description="Generate custom security quizzes for team training. Pick from 4 topics — phishing, passwords, remote work, and data privacy."
        icon="📝"
        href="/tools/employee-training-quiz/"
      />
    </div>

    <div class="mt-16 rounded-2xl bg-gray-50 p-8 text-center">
      <h2 class="text-xl font-bold text-gray-900">How Our Tools Work</h2>
      <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-3">
        <div>
          <div class="text-3xl mb-3">1️⃣</div>
          <h3 class="font-semibold text-gray-900">Runs in Your Browser</h3>
          <p class="mt-2 text-sm text-gray-600">All tools are client-side only. Nothing you type is ever sent to our servers.</p>
        </div>
        <div>
          <div class="text-3xl mb-3">2️⃣</div>
          <h3 class="font-semibold text-gray-900">Instant Results</h3>
          <p class="mt-2 text-sm text-gray-600">No waiting, no processing. Get your results immediately.</p>
        </div>
        <div>
          <div class="text-3xl mb-3">3️⃣</div>
          <h3 class="font-semibold text-gray-900">100% Free, Always</h3>
          <p class="mt-2 text-sm text-gray-600">No premium tiers. No hidden fees. These tools will always be free.</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
