---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SecurityAssessment from '../../components/SecurityAssessment';
---

<BaseLayout
  title="Free Security Assessment for Small Business"
  description="Take our free 3-minute cybersecurity assessment. Answer 20 simple questions and get a personalized risk score with actionable recommendations for your small business."
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center mb-12">
      <h1 class="text-4xl font-extrabold tracking-tight text-gray-900">Security Assessment</h1>
      <p class="mt-4 text-lg text-gray-600">
        Answer 20 simple questions about your business's security practices. Get a personalized risk score and an actionable improvement plan — all in under 3 minutes.
      </p>
      <div class="mt-4 inline-flex items-center gap-2 rounded-full bg-accent-50 px-4 py-1.5 text-sm font-medium text-accent-700">
        🔒 Your answers never leave your browser
      </div>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white p-6 sm:p-10 shadow-sm">
      <SecurityAssessment client:load />
    </div>
  </div>
</BaseLayout>
