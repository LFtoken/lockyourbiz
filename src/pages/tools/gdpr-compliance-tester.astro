---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GdprComplianceTester from '../../components/GdprComplianceTester';
---

<BaseLayout
  title="GDPR Compliance Score Tester | Free Online Tool"
  description="Free GDPR compliance self-assessment for small businesses. Answer 8 questions about your data practices and get an instant readiness score with specific recommendations."
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center mb-12">
      <h1 class="text-4xl font-extrabold tracking-tight text-gray-900">GDPR Compliance Score Tester</h1>
      <p class="mt-4 text-lg text-gray-600">
        Not sure if your small business complies with GDPR? Answer 8 quick questions and get an instant readiness score with actionable recommendations. Free, no sign-up required.
      </p>
      <div class="mt-4 inline-flex items-center gap-2 rounded-full bg-accent-50 px-4 py-1.5 text-sm font-medium text-accent-700">
        🇪🇺 All data stays on your device — nothing is sent anywhere
      </div>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white p-6 sm:p-10 shadow-sm max-w-2xl mx-auto">
      <GdprComplianceTester client:load />
    </div>
  </div>
</BaseLayout>
