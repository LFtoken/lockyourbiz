---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhishingQuiz from '../../components/PhishingQuiz';
---

<BaseLayout
  title="Phishing Email Quiz: Can You Spot the Scam?"
  description="Test your ability to spot phishing emails with our free interactive quiz. 10 realistic email scenarios with expert feedback on every answer. No sign-up required."
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center mb-12">
      <h1 class="text-4xl font-extrabold tracking-tight text-gray-900">Phishing Email Quiz</h1>
      <p class="mt-4 text-lg text-gray-600">
        10 realistic emails. Can you tell which ones are real and which ones are trying to steal your information? Learn the patterns that keep your business safe.
      </p>
      <div class="mt-4 inline-flex items-center gap-2 rounded-full bg-accent-50 px-4 py-1.5 text-sm font-medium text-accent-700">
        🔒 Nothing you do is tracked or stored
      </div>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white p-6 sm:p-10 shadow-sm">
      <PhishingQuiz client:load />
    </div>

    <div class="mt-16 mx-auto max-w-2xl text-center">
      <p class="text-sm text-gray-500">
        Want to learn more about protecting your business from phishing? Read our{' '}
        <a href="/blog/phishing-prevention/" class="font-medium text-primary-600 hover:text-primary-700">complete phishing prevention guide</a>.
      </p>
    </div>
  </div>
</BaseLayout>
