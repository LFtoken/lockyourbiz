---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolComparison from '../../components/ToolComparison';
---

<BaseLayout
  title="Free Security Tool Comparison | Compare Password Managers, Antivirus & More"
  description="Compare the best free cybersecurity tools for small businesses. Side-by-side comparison of password managers, antivirus, backup solutions, firewalls, and more."
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center mb-12">
      <h1 class="text-4xl font-extrabold tracking-tight text-gray-900">Free Security Tool Comparison</h1>
      <p class="mt-4 text-lg text-gray-600">
        Click on any two or more tools to compare them side by side. Find the best free security software for your small business — password managers, antivirus, backup, firewalls, and more.
      </p>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white p-6 sm:p-10 shadow-sm">
      <ToolComparison client:load />
    </div>
  </div>
</BaseLayout>
