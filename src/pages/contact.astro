---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with Small Biz Security. We welcome your questions, feedback, and suggestions about cybersecurity for small businesses."
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-4xl font-extrabold tracking-tight text-gray-900">Contact Us</h1>
      <p class="mt-4 text-lg text-gray-600">
        Have a question about cybersecurity for your small business? Found a bug in one of our tools? Have a suggestion for a guide we should write? We would love to hear from you.
      </p>

      <div class="mt-10 grid grid-cols-1 gap-8 sm:grid-cols-2">
        <div class="rounded-2xl border border-gray-200 p-6">
          <h3 class="text-lg font-semibold text-gray-900">Email Us</h3>
          <p class="mt-2 text-sm text-gray-600">
            For general inquiries, feedback, or suggestions:
          </p>
          <a href="mailto:hello@lockyourbiz.com" class="mt-3 inline-block text-primary-600 font-medium hover:text-primary-700">
            hello@lockyourbiz.com
          </a>
        </div>

        <div class="rounded-2xl border border-gray-200 p-6">
          <h3 class="text-lg font-semibold text-gray-900">Response Time</h3>
          <p class="mt-2 text-sm text-gray-600">
            We aim to respond to all inquiries within 1–2 business days. For urgent security incidents, please contact a qualified cybersecurity professional immediately — we are not an incident response service.
          </p>
        </div>
      </div>

      <div class="mt-12 rounded-2xl border border-gray-200 bg-gray-50 p-8">
        <h2 class="text-xl font-bold text-gray-900">Send Us a Message</h2>
        <form
          class="mt-6 space-y-5"
          action="https://formspree.io/f/xxxxxxxx"
          method="POST"
          id="contact-form"
        >
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700">Your Name</label>
            <input type="text" id="name" name="name" required class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3.5 shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none" placeholder="John Smith" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700">Email Address</label>
            <input type="email" id="email" name="email" required class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3.5 shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none" placeholder="john@yourbusiness.com" />
          </div>
          <div>
            <label for="subject" class="block text-sm font-medium text-gray-700">Subject</label>
            <select id="subject" name="subject" required class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3.5 shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none bg-white">
              <option value="">Select a topic...</option>
              <option value="General Question">General Question</option>
              <option value="Tool Feedback">Tool Feedback / Bug Report</option>
              <option value="Article Suggestion">Article Suggestion</option>
              <option value="Privacy Concern">Privacy / Data Request</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700">Message</label>
            <textarea id="message" name="message" rows={5} required class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3.5 shadow-sm focus:border-primary-500 focus:ring-primary-500 focus:outline-none" placeholder="Tell us what is on your mind..."></textarea>
          </div>
          <button type="submit" class="btn-primary cursor-pointer">
            Send Message
          </button>
        </form>
        <p class="mt-4 text-xs text-gray-500">
          This form sends your message directly to <strong>hello@lockyourbiz.com</strong>. We will never share your email or use it for anything other than replying to your message.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // Fallback: if Formspree is not configured yet, use mailto as fallback
  const form = document.getElementById('contact-form');
  if (form) {
    form.addEventListener('submit', function(e) {
      const action = form.getAttribute('action');
      // If the form action is still the placeholder, use mailto fallback
      if (action && action.includes('xxxxxxxx')) {
        e.preventDefault();
        const name = (document.getElementById('name') as HTMLInputElement)?.value || '';
        const email = (document.getElementById('email') as HTMLInputElement)?.value || '';
        const subject = (document.getElementById('subject') as HTMLSelectElement)?.value || '';
        const message = (document.getElementById('message') as HTMLTextAreaElement)?.value || '';

        const body = `From: ${name} (${email})%0D%0A%0D%0A${message}`;
        const mailto = `mailto:hello@lockyourbiz.com?subject=${encodeURIComponent(subject)}&body=${body}`;
        window.location.href = mailto;
      }
    });
  }
</script>
