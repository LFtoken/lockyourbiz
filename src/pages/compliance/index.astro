---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHero from '../../components/SectionHero.astro';
import AdSlot from '../../components/AdSlot.astro';
import AdNativeCard from '../../components/AdNativeCard.astro';

const regulations = [
  {
    title: 'FTC Safeguards Rule',
    icon: '🇺🇸',
    href: '/compliance/ftc-safeguards/',
    description: 'The US federal regulation requiring financial institutions — including many small businesses — to implement specific data security measures. Fines up to $100,000 per violation.',
    who: 'US financial services, auto dealers, mortgage brokers, payday lenders',
    penalty: 'Up to $100,000 per violation',
  },
  {
    title: 'GDPR / UK GDPR',
    icon: '🇪🇺',
    href: '/compliance/gdpr/',
    description: 'The EU and UK data protection regulation that applies to ANY business handling European customer data — even if you are not based in Europe.',
    who: 'Any business with EU/UK customers or website visitors',
    penalty: 'Up to €20 million or 4% of global annual turnover',
  },
  {
    title: 'CCPA / CPRA',
    icon: '🇺🇸',
    href: '/compliance/ccpa/',
    description: 'California Consumer Privacy Act — the strongest state-level privacy law in the US, with rights to know, delete, and opt out of data sales.',
    who: 'Businesses serving California residents with $25M+ revenue or 100K+ consumer records',
    penalty: '$2,500 per unintentional violation; $7,500 per intentional violation',
  },
  {
    title: 'HIPAA',
    icon: '🏥',
    href: '/compliance/hipaa/',
    description: 'Health Insurance Portability and Accountability Act — governs how healthcare providers, insurers, and their business associates handle protected health information (PHI).',
    who: 'Healthcare providers, health plans, healthcare clearinghouses, and business associates',
    penalty: '$100 — $50,000 per violation, up to $1.5M per year',
  },
  {
    title: 'PDPA / PDP (Southeast Asia)',
    icon: '🌏',
    href: '/compliance/pdpa/',
    description: 'Singapore Personal Data Protection Act and Thailand Personal Data Protection Act — two major Asian privacy frameworks affecting cross-border e-commerce sellers.',
    who: 'Businesses collecting personal data in Singapore or Thailand',
    penalty: 'PDPA: Up to S$1M; PDP: Up to 5M THB + criminal liability',
  },
];

const toolkitItems = [
  {
    title: 'Compliance Toolkit',
    icon: '🧰',
    href: '/compliance/compliance-toolkit/',
    description: 'Templates, checklists, and step-by-step guides: privacy policy generator, cookie consent setup, data breach notification letter template, and regulatory gap analysis worksheet.',
  },
];
---

<BaseLayout
  title="Small Business Compliance Guides — FTC, GDPR, CCPA, HIPAA & More"
  description="Plain-English compliance guides for small businesses. FTC Safeguards Rule, GDPR, CCPA/CPRA, HIPAA, PDPA. Templates, checklists, and penalty avoidance guides."
>
  <SectionHero
    icon="📜"
    title="Global Compliance, Plain English"
    description="Privacy regulations are complicated. Fines are not. Whether you sell to customers in the US, Europe, or Southeast Asia, we break down exactly what you need to do — no legal jargon."
    badge="📜 Global Compliance Guides"
  />

  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <AdSlot variant="banner" />

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
      {regulations.map((reg) => (
        <a href={reg.href} class="group card no-underline hover:border-primary-300">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-3xl" aria-hidden="true">{reg.icon}</span>
            <h2 class="text-lg font-bold text-gray-900 group-hover:text-primary-700 transition-colors">
              {reg.title}
            </h2>
          </div>
          <p class="text-sm text-gray-600 leading-relaxed mb-3">
            {reg.description}
          </p>
          <div class="space-y-1.5 text-xs text-gray-500">
            <p><strong class="text-gray-700">Who it applies to:</strong> {reg.who}</p>
            <p><strong class="text-gray-700">Maximum penalty:</strong> <span class="text-red-600 font-medium">{reg.penalty}</span></p>
          </div>
        </a>
      ))}
      {toolkitItems.map((item) => (
        <a href={item.href} class="group card no-underline hover:border-primary-300 border-2 border-dashed border-primary-300 bg-primary-50/50">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-3xl" aria-hidden="true">{item.icon}</span>
            <h2 class="text-lg font-bold text-gray-900 group-hover:text-primary-700 transition-colors">
              {item.title}
            </h2>
          </div>
          <p class="text-sm text-gray-600 leading-relaxed">
            {item.description}
          </p>
        </a>
      ))}
    </div>

    <AdNativeCard
      title="Start With These Free Resources"
      resources={[
        { title: 'Security Assessment', description: '20 questions to identify your compliance gaps in 3 minutes.', href: '/tools/security-assessment/', icon: '📋', badge: 'Free Tool' },
        { title: 'Small Business Backup Strategy', description: 'Data backup is required by nearly every regulation. Here is your plan.', href: '/blog/small-business-backup-strategy/', icon: '💾', badge: 'Guide' },
        { title: 'Privacy Policy Template', description: 'Part of our compliance toolkit — a customizable privacy policy for your site.', href: '/compliance/compliance-toolkit/', icon: '📝', badge: 'Template' },
      ]}
    />
  </div>
</BaseLayout>
