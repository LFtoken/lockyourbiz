---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="Sorry, the page you are looking for does not exist. Browse our free cybersecurity guides and tools for small business owners."
>
  <div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8 text-center">
    <div class="text-6xl mb-6">🔍</div>
    <h1 class="text-4xl font-extrabold tracking-tight text-gray-900 sm:text-5xl">Page Not Found</h1>
    <p class="mt-4 text-lg text-gray-600 max-w-lg mx-auto">
      The page you are looking for does not exist or has been moved. Here are some places to start:
    </p>

    <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 max-w-3xl mx-auto">
      <a href="/" class="card no-underline hover:border-primary-300 text-left">
        <span class="text-2xl">🏠</span>
        <h3 class="mt-2 font-semibold text-gray-900">Home</h3>
        <p class="mt-1 text-xs text-gray-500">Start here</p>
      </a>
      <a href="/tools/" class="card no-underline hover:border-primary-300 text-left">
        <span class="text-2xl">🛠️</span>
        <h3 class="mt-2 font-semibold text-gray-900">Free Tools</h3>
        <p class="mt-1 text-xs text-gray-500">9 interactive tools</p>
      </a>
      <a href="/blog/" class="card no-underline hover:border-primary-300 text-left">
        <span class="text-2xl">📖</span>
        <h3 class="mt-2 font-semibold text-gray-900">Guides</h3>
        <p class="mt-1 text-xs text-gray-500">17 articles</p>
      </a>
      <a href="/threat-alerts/" class="card no-underline hover:border-primary-300 text-left">
        <span class="text-2xl">🚨</span>
        <h3 class="mt-2 font-semibold text-gray-900">Threat Alerts</h3>
        <p class="mt-1 text-xs text-gray-500">Live CISA feed</p>
      </a>
    </div>
  </div>
</BaseLayout>
