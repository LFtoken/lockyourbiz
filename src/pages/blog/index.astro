const categories = ['All', 'Getting Started', 'Threats', 'Tools & Tech', 'Hardware & Services', 'Policies & Planning'];
---

<BaseLayout
  title="Cybersecurity Guides for Small Business"
  description="Free, plain-English cybersecurity guides for small business owners. Learn about phishing, ransomware, remote work security, and the best free security tools."
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-gray-900">Guides &amp; Articles</h1>
      <p class="mt-4 text-lg text-gray-600">
        Step-by-step cybersecurity guides written for small business owners. No jargon, no enterprise tools you cannot afford — just practical advice you can use today.
      </p>
    </div>

    <!-- Category Filter -->
    <div class="mt-10 flex flex-wrap justify-center gap-2" id="category-filters">
      {categories.map((cat) => (
        <button
          class="filter-btn rounded-full px-4 py-2.5 text-sm font-medium transition-colors border border-gray-300 bg-white text-gray-700 hover:border-primary-400 hover:text-primary-700 data-[active=true]:bg-primary-600 data-[active=true]:text-white data-[active=true]:border-primary-600 min-h-[44px]"
          data-category={cat}
        >
          {cat}
        </button>
      ))}
    </div>

    <div class="mt-10 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3" id="articles-grid">
      {articles.map((article) => (
        <div class="article-card-wrapper" data-category={article.category}>
          <ArticleCard {...article} />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  // Category filter logic
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.article-card-wrapper');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category');

      // Update active button style
      buttons.forEach((b) => { b.removeAttribute('data-active'); });
      btn.setAttribute('data-active', 'true');

      // Show/hide cards
      cards.forEach((card) => {
        const cardCat = card.getAttribute('data-category');
        if (category === 'All' || cardCat === category) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });

  // Set "All" as active by default
  const allBtn = document.querySelector('[data-category="All"]');
  if (allBtn) allBtn.setAttribute('data-active', 'true');
</script>
