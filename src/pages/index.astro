---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/HeroCarousel';
import ToolCard from '../components/ToolCard.astro';
import ArticleCard from '../components/ArticleCard.astro';

const featuredArticles = [
  {
    title: 'Cybersecurity 101 for Small Business Owners',
    excerpt: 'Everything you need to protect your business from cyber threats — passwords, 2FA, backups, phishing, and more. In plain English, no technical background required.',
    href: '/blog/cybersecurity-101/',
    date: '2026-07-10',
    category: 'Getting Started',
    readTime: '8',
  },
  {
    title: 'Ransomware Protection: What Small Businesses Need to Know',
    excerpt: 'Ransomware can destroy a small business overnight. Learn how it works, how to prevent it, and exactly what to do if you are attacked.',
    href: '/blog/ransomware-protection/',
    date: '2026-06-28',
    category: 'Threats',
    readTime: '9',
  },
  {
    title: 'Cloud & SaaS Security: Stop Account Takeover & Shadow IT',
    excerpt: 'Your business runs on 40-60 SaaS apps. Lock them down with MFA, SSO, sharing controls, and a proper offboarding checklist.',
    href: '/blog/saas-security-guide/',
    date: '2026-07-21',
    category: 'Tools & Tech',
    readTime: '9',
  },
];
---

<BaseLayout
  title="Free Cybersecurity Tools & Guides for Small Business"
  description="Practical cybersecurity advice, free tools, and step-by-step guides for small business owners. No jargon. No enterprise budget required. Just actionable steps to protect your business."
>
  <HeroCarousel client:load />

  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="section-title">Free Tools to Secure Your Business</h2>
        <p class="section-subtitle max-w-2xl mx-auto">No sign-up required. No email collection. Just practical tools that work.</p>
      </div>
      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <ToolCard title="Security Assessment" description="20 questions, personalized risk score, actionable recommendations. Takes 3 minutes." icon="📋" href="/tools/security-assessment/" />
        <ToolCard title="Password Strength Checker" description="Test password strength, see estimated crack time, and learn how to improve." icon="🔐" href="/tools/password-checker/" />
        <ToolCard title="Phishing Email Quiz" description="10 real-world email scenarios. Can your team spot the fakes? Instant feedback." icon="🎣" href="/tools/phishing-quiz/" />
        <ToolCard title="GDPR Compliance Tester" description="8 questions to assess your GDPR readiness. Get a score and action plan instantly." icon="🇪🇺" href="/tools/gdpr-compliance-tester/" />
        <ToolCard title="Website Vulnerability Scanner" description="12-point checklist to audit your website security with specific fix instructions." icon="🌐" href="/tools/website-vulnerability-scanner/" />
        <ToolCard title="SMB Security Budget Calculator" description="Calculate your recommended cybersecurity budget with a category breakdown." icon="💰" href="/tools/smb-budget-calculator/" />
        <ToolCard title="MFA Eligibility Checker" description="See which of your services support MFA and get step-by-step setup instructions." icon="🔐" href="/tools/mfa-eligibility-checker/" />
        <ToolCard title="Training Quiz Generator" description="Generate custom security quizzes for team training on phishing, passwords & more." icon="📝" href="/tools/employee-training-quiz/" />
        <ToolCard title="Free Tool Comparison" description="Compare the best free security tools side by side across all categories." icon="⚖️" href="/tools/tool-comparison/" />
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="section-title">Latest Guides</h2>
          <p class="section-subtitle">Step-by-step, no jargon, written for business owners.</p>
        </div>
        <a href="/blog/" class="btn-secondary hidden sm:inline-flex no-underline">View All Guides &rarr;</a>
      </div>
      <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {featuredArticles.map((article) => (<ArticleCard {...article} />))}
      </div>
      <div class="mt-8 text-center sm:hidden">
        <a href="/blog/" class="btn-secondary no-underline">View All Guides &rarr;</a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="section-title">Protect Your Business in 3 Steps</h2>
        <p class="section-subtitle max-w-2xl mx-auto">You do not need an IT degree. You just need a plan.</p>
      </div>
      <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary-100 text-2xl font-bold text-primary-700">1</div>
          <h3 class="mt-5 text-lg font-semibold text-gray-900">Take the Assessment</h3>
          <p class="mt-2 text-sm text-gray-600">Find out where your business is vulnerable in 3 minutes with our free security quiz.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary-100 text-2xl font-bold text-primary-700">2</div>
          <h3 class="mt-5 text-lg font-semibold text-gray-900">Pick Your Tools</h3>
          <p class="mt-2 text-sm text-gray-600">Use our comparison tool to find the right free security software for your needs and budget.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary-100 text-2xl font-bold text-primary-700">3</div>
          <h3 class="mt-5 text-lg font-semibold text-gray-900">Follow the Guides</h3>
          <p class="mt-2 text-sm text-gray-600">Step-by-step instructions to set everything up, written for people who are not IT professionals.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-primary-700">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white">Ready to stop being an easy target?</h2>
      <p class="mt-3 text-lg text-primary-100">Take our free 3-minute security assessment and get a personalized action plan.</p>
      <a href="/tools/security-assessment/" class="mt-8 inline-flex items-center rounded-lg bg-white px-8 py-4 text-base font-semibold text-primary-700 shadow-sm hover:bg-primary-50 transition-colors no-underline">Start Free Assessment &rarr;</a>
    </div>
  </section>
</BaseLayout>
